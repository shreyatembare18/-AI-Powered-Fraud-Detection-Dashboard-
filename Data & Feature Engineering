import pandas as pd
 import numpy as np
 def engineer(df: pd.DataFrame) -> pd.DataFrame:
 # Original anonymised V1‑V28 are already PCA components
 df['hour'] = pd.to_datetime(df['Time'], unit='s').dt.hour
 df['amount_log'] = np.log1p(df['Amount'])
 # Simple velocity feature: transactions per minute per card (mocked here)
 df['txn_per_min'] = df.groupby('card_id')['Time'].transform(
 lambda x: x.diff().fillna(0).apply(lambda d: 60/d if d>0 else 0)
 )
 df = df.fillna(0)
 return df
 data = pd.read_csv('data/creditcard.csv')
 data = engineer(data)
 X = data.drop(columns=['Class'])
 y = data['Class']
